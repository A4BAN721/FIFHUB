# Supabase Configuration
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only database connection string. Do NOT expose this to client components.
# Get this from Supabase project settings -> Database -> Connection string
DATABASE_URL=postgresql://postgres.your-project-id:YOUR-PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# Server-only Supabase service role key (for API routes)
# Get this from Supabase project settings -> API -> service_role key (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis Configuration (optional - uses in-memory cache as fallback)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# External Football API Keys (optional)
# Live score provider order. FotMob is the default primary source; set FOTMOB_ENABLED=0 to disable it.
LIVE_SCORE_PROVIDER_ORDER=fotmob,espn,football-data,api-football
FOTMOB_ENABLED=1
FOTMOB_API_BASE_URL=https://www.fotmob.com/api/data

# API-Football: https://www.api-football.com
API_FOOTBALL_KEY=
# Football-Data.org: https://www.football-data.org
FOOTBALL_DATA_KEY=
